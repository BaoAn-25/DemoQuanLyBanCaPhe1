<%- include('partials/head', { title: 'Thanh toán - Coffee Express' }) %>
<%- include('partials/navbar') %>

<div class="container py-5">
  <%- include('partials/flash') %>

  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="fw-bold mb-4">🛒 Xác nhận đơn hàng</h2>

      <div class="row mb-4">
        <!-- Danh sách sản phẩm -->
        <div class="col-md-8">
          <div class="card shadow mb-3">
            <div class="card-header bg-light">
              <h5 class="mb-0">Sản phẩm trong giỏ</h5>
            </div>
            <div class="card-body">
              <% items.forEach((item) => { %>
              <div class="row mb-3 pb-3 border-bottom">
                <div class="col-md-2 mb-2">
                  <img src="<%= item.image_url %>" alt="<%= item.name %>" class="img-fluid rounded" style="max-height: 60px;" />
                </div>
                <div class="col-md-6">
                  <h6 class="mb-1"><%= item.name %></h6>
                  <small class="text-muted">
                    Giá: ₫<%= item.price.toLocaleString('vi-VN') %> × <%= item.quantity %> = 
                    <strong>₫<%= item.subTotal.toLocaleString('vi-VN') %></strong>
                  </small>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
        </div>

        <!-- Tóm tắt thanh toán -->
        <div class="col-md-4">
          <div class="card shadow">
            <div class="card-body">
              <h5 class="card-title mb-3">Tóm tắt</h5>

              <div class="mb-3">
                <div class="d-flex justify-content-between mb-2">
                  <span>Tổng tiền:</span>
                  <strong>₫<%= total.toLocaleString('vi-VN') %></strong>
                </div>
              </div>

              <hr />

              <div class="mb-3">
                <p class="text-muted mb-2">Số dư ví hiện tại:</p>
                <p class="h5 text-success mb-0">
                  ₫<%= (user.wallet_balance || 0).toLocaleString('vi-VN') %>
                </p>
              </div>

              <% if ((user.wallet_balance || 0) >= total) { %>
              <form action="/orders/checkout" method="POST">
                <button type="submit" class="btn btn-success btn-lg w-100">
                  <i class="bi bi-check-circle me-2"></i>Xác nhận thanh toán
                </button>
              </form>
              <% } else { %>
              <div class="alert alert-danger mb-0">
                <small>
                  <i class="bi bi-exclamation-triangle me-1"></i>
                  Số dư không đủ. Cần nạp thêm ₫<%= (total - (user.wallet_balance || 0)).toLocaleString('vi-VN') %>
                </small>
              </div>
              <a href="/wallet/deposit" class="btn btn-warning btn-lg w-100 mt-2">
                <i class="bi bi-plus-circle me-2"></i>Nạp tiền
              </a>
              <% } %>

              <a href="/products/cart" class="btn btn-outline-secondary btn-lg w-100 mt-2">
                <i class="bi bi-arrow-left me-2"></i>Quay lại giỏ hàng
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
