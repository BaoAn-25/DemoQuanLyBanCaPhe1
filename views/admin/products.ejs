<%- include('../partials/head', { title: 'Admin Products' }) %>
<%- include('../partials/navbar') %>
<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
    <div>
      <h1 class="mb-2">Quản lý sản phẩm</h1>
      <p class="text-muted">Xem, sửa, xóa, và thêm sản phẩm mới.</p>
    </div>
    <a href="/admin/products/new" class="btn btn-success btn-lg">+ Thêm sản phẩm mới</a>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-sm-4 col-md-3">
      <div class="card shadow-sm border-0 admin-summary-card">
        <div class="card-body py-3">
          <h5 class="card-title">Tổng sản phẩm</h5>
          <p class="display-6 m-0"><%= products.length %></p>
        </div>
      </div>
    </div>
    <div class="col-sm-4 col-md-3">
      <div class="card shadow-sm border-0 admin-summary-card">
        <div class="card-body py-3">
          <h5 class="card-title">Danh mục</h5>
          <p class="display-6 m-0"><%= [...new Set(products.map(p => p.category))].length %></p>
        </div>
      </div>
    </div>
    <div class="col-sm-4 col-md-3">
      <div class="card shadow-sm border-0 admin-summary-card">
        <div class="card-body py-3">
          <h5 class="card-title">Giá trung bình</h5>
          <p class="display-6 m-0">₫<%= products.length ? Math.round(products.reduce((s, p) => s + Number(p.price), 0) / products.length).toLocaleString('vi-VN') : 0 %></p>
        </div>
      </div>
    </div>
  </div>

  <% if (products.length === 0) { %>
    <div class="alert alert-info">Hiện chưa có sản phẩm nào. Vui lòng thêm sản phẩm mới.</div>
  <% } else { %>
  <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Hình ảnh</th>
          <th>Tên</th>
          <th>Giá</th>
          <th>Danh mục</th>
          <th class="text-center">Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach((product) => { %>
          <tr>
            <td class="w-25">
              <img src="<%= product.image_url || '/images/products/default.jpg' %>" alt="<%= product.name %>" class="img-thumbnail product-thumb" />
            </td>
            <td><strong><%= product.name %></strong><br/><small class="text-muted"><%= product.description ? product.description.slice(0, 60) + (product.description.length > 60 ? '...' : '') : '-' %></small></td>
            <td class="text-nowrap">₫<%= Number(product.price).toLocaleString('vi-VN') %></td>
            <td><span class="badge bg-primary"><%= product.category %></span></td>
            <td class="text-center">
              <a href="/admin/products/<%= product.id %>/edit" class="btn btn-sm btn-warning me-2">Sửa</a>
              <form action="/admin/products/<%= product.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Xóa sản phẩm?')">
                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>