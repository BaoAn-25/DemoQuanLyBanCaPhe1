<%- include('../partials/head', { title: 'Sửa tài khoản' }) %>
<%- include('../partials/navbar') %>
<div class="container py-4">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
      <h1 class="h4 mb-0">Sửa tài khoản</h1>
      <p class="small mb-0">Chỉ chỉnh được thông tin và vai trò, không sửa được số dư ví</p>
    </div>
    <div class="card-body">
      <form action="/admin/users/<%= user.id %>/update" method="POST">
        <div class="mb-3">
          <label class="form-label">Tên đăng nhập</label>
          <input type="text" name="username" class="form-control" required value="<%= user.username %>" />
    </div>
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required value="<%= user.email %>" />
    </div>
    <div class="mb-3">
      <label class="form-label">Vai trò</label>
      <select name="role" class="form-control" required>
        <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
        <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Số dư ví (không thể chỉnh sửa)</label>
      <input type="text" class="form-control" value="₫<%= (user.wallet_balance || 0).toLocaleString('vi-VN') %>" readonly />
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-success">💾 Cập nhật</button>
      <a href="/admin/users" class="btn btn-secondary">↩️ Quay lại</a>
    </div>
  </form>
</div>
</div>
</div>
<%- include('../partials/footer') %>