<%- include('../partials/head', { title: 'Admin Order Detail' }) %>
<%- include('../partials/navbar') %>
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <div>
      <h1 class="mb-1">Chi tiết đơn hàng</h1>
      <p class="mb-0 text-muted">Mã đơn: <strong><%= order.id %></strong></p>
      <p class="mb-0">Khách hàng: <strong><%= order.username %></strong> - <%= order.email %></p>
      <p class="mb-0">Ngày đặt: <strong><%= new Date(order.created_at.toDate ? order.created_at.toDate() : order.created_at).toLocaleString('vi-VN') %></strong></p>
    </div>
    <div>
      <span class="badge fs-6 <%=
        order.status === 'completed' ? 'bg-success' :
        order.status === 'pending' ? 'bg-warning text-dark' :
        order.status === 'processing' ? 'bg-info text-dark' :
        order.status === 'shipped' ? 'bg-primary' :
        order.status === 'cancelled' ? 'bg-danger' : 'bg-secondary'
      %>"><%= 
        order.status === 'completed' ? 'Hoàn thành' :
        order.status === 'pending' ? 'Chờ xử lý' :
        order.status === 'processing' ? 'Đang xử lý' :
        order.status === 'shipped' ? 'Đang giao' :
        order.status === 'cancelled' ? 'Đã hủy' : 'Không xác định'
      %></span>
    </div>
  </div>

  <form action="/admin/orders/<%= order.id %>/update-status" method="POST" class="mb-4">
    <div class="row g-2 align-items-center">
      <div class="col-md-3">
        <select class="form-select" name="status">
          <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Chờ xử lý</option>
          <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Đang xử lý</option>
          <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Đang giao</option>
          <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Hoàn thành</option>
          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Hủy đơn</option>
        </select>
      </div>
      <div class="col-md-auto">
        <button type="submit" class="btn btn-success">Cập nhật trạng thái</button>
        <a href="/admin/orders" class="btn btn-secondary ms-2">Quay lại</a>
      </div>
    </div>
  </form>

  <div class="mb-4">
    <h5>Sản phẩm trong đơn hàng (<%= Array.isArray(order.items) ? order.items.length : 0 %>)</h5>
    <div class="row g-3">
      <% if (Array.isArray(order.items) && order.items.length > 0) { %>
        <% order.items.forEach(item => { %>
          <div class="col-12 col-md-6">
            <div class="card order-item-card h-100">
              <div class="row g-0 align-items-center">
                <div class="col-4">
                  <img src="<%= item.image_url || '/images/products/default.jpg' %>" class="img-fluid rounded-start" alt="<%= item.name %>" style="height: 140px; object-fit: contain; width: 100%; background: #f8f9fa; padding: 8px;" />
                </div>
                <div class="col-8">
                  <div class="card-body py-2">
                    <h6 class="card-title mb-1"><%= item.name %></h6>
                    <p class="card-text mb-1"><strong>Số lượng:</strong> <%= item.quantity %></p>
                    <p class="card-text mb-1"><strong>Giá:</strong> ₫<%= Number(item.price).toLocaleString('vi-VN') %></p>
                    <p class="card-text mb-0"><strong>Thành tiền:</strong> ₫<%= Number(item.subTotal).toLocaleString('vi-VN') %></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="col-12">
          <div class="alert alert-warning mb-0">Không có sản phẩm trong đơn hàng này.</div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card p-3 mb-4 bg-light">
    <div class="d-flex justify-content-between align-items-center">
      <span class="fw-bold">Tổng tiền đơn hàng</span>
      <span class="fs-4 text-danger fw-bold">₫<%= Number(order.total_amount).toLocaleString('vi-VN') %></span>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>