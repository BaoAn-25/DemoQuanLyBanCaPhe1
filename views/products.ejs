<%- include('partials/head', { title: 'Menu - Coffee Express' }) %>
<%- include('partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Menu</h2>
    <div class="d-flex align-items-center gap-3">
      <div class="text-muted">Xin chào, <%= typeof currentUser !== 'undefined' && currentUser ? currentUser.username : 'Khách' %>!</div>
    </div>
  </div>

  <div class="row mb-5 align-items-center g-3">
    <div class="col-12">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <p class="mb-0 text-muted">Lọc theo danh mục, nút tìm kiếm nằm trên thanh điều hướng.</p>
        <form action="/products" method="GET" class="w-100 w-md-50">
          <div class="input-group shadow-sm rounded-pill overflow-hidden border">
            <select name="category" class="form-select border-0 px-4 py-2 fw-medium bg-white text-dark" onchange="this.form.submit()" style="cursor: pointer;">
              <option value="">☕ Tất cả thức uống</option>
              <% if (typeof categories !== 'undefined' && categories.length) { %>
                <% categories.forEach((cat) => { %>
                  <option value="<%= cat.name %>" <%= typeof categoryFilter !== 'undefined' && categoryFilter === cat.name ? 'selected' : '' %>><%= cat.name %></option>
                <% }); %>
              <% } else { %>
                <option value="Espresso" <%= typeof categoryFilter !== 'undefined' && categoryFilter === 'Espresso' ? 'selected' : '' %>>Espresso</option>
                <option value="Latte" <%= typeof categoryFilter !== 'undefined' && categoryFilter === 'Latte' ? 'selected' : '' %>>Latte</option>
                <option value="Cold Brew" <%= typeof categoryFilter !== 'undefined' && categoryFilter === 'Cold Brew' ? 'selected' : '' %>>Cold Brew</option>
                <option value="Cappuccino" <%= typeof categoryFilter !== 'undefined' && categoryFilter === 'Cappuccino' ? 'selected' : '' %>>Cappuccino</option>
              <% } %>
            </select>
            <button type="submit" class="btn btn-dark px-4 fw-medium">Áp dụng</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <% if (typeof noResultsMessage !== 'undefined' && noResultsMessage) { %>
    <div class="alert alert-warning mt-3" role="alert">
      <%= noResultsMessage %>
    </div>
  <% } %>

  <div class="row g-4">
    <% if (typeof products !== 'undefined') { %>
      <% products.forEach((product) => { %>
      <div class="col-md-4">
        <div class="card product-card h-100 shadow-sm">
          <img src="<%= product.image_url %>" class="card-img-top" alt="<%= product.name %>" />
          <div class="card-body d-flex flex-column">
            <div>
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text text-muted"><%= product.description %></p>
            </div>
            <div class="mt-auto">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="price">đ<%= product.price.toLocaleString('vi-VN') %></span>
                <span class="badge bg-warning text-dark"><%= product.category %></span>
              </div>
              <div class="d-flex gap-2">
                <form action="/products/add-to-cart" method="POST" class="flex-grow-1 add-to-cart-form">
                  <input type="hidden" name="productId" value="<%= product.id %>" />
                  <button type="submit" class="btn btn-primary btn-sm w-100">Thêm vào giỏ</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>