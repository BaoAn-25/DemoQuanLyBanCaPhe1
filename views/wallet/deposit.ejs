<%- include('../partials/head', { title: 'Nạp tiền - Coffee Express' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <%- include('../partials/flash') %>

  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-body p-4">
          <h2 class="card-title mb-3">💰 Nạp tiền vào ví</h2>
          <p class="text-muted">Điền số tiền muốn nạp vào tài khoản của bạn</p>

          <form action="/wallet/deposit" method="POST" class="mt-4">
            <div class="mb-3">
              <label for="amount" class="form-label">Số tiền (VNĐ)</label>
              <input
                type="number"
                name="amount"
                id="amount"
                class="form-control form-control-lg"
                placeholder="Ví dụ: 50000"
                min="10000"
                step="10000"
                required
              />
              <small class="text-muted">Tối thiểu 10,000 VNĐ</small>
            </div>

            <div class="mb-3">
              <label for="paymentMethod" class="form-label">Phương thức thanh toán</label>
              <select name="paymentMethod" id="paymentMethod" class="form-select form-select-lg" required>
                <option value="">-- Chọn phương thức --</option>
                <option value="Momo">Momo</option>
                <option value="Tiền mặt">Tiền mặt tại quầy</option>
                <option value="Tài khoản ngân hàng">Thanh toán bằng tài khoản ngân hàng</option>
              </select>
            </div>

            <!-- Trường nhập tên và số tài khoản ngân hàng (ẩn mặc định) -->
            <div id="bankAccountSection" class="mb-3" style="display: none;">
              <label for="bankName" class="form-label">Tên ngân hàng</label>
              <input
                type="text"
                name="bankName"
                id="bankName"
                class="form-control form-control-lg mb-2"
                placeholder="Ví dụ: Vietcombank, ACB, MB, ..."
              />

              <label for="bankAccount" class="form-label">Số tài khoản ngân hàng</label>
              <input
                type="text"
                name="bankAccount"
                id="bankAccount"
                class="form-control form-control-lg"
                placeholder="Ví dụ: 1234567890"
              />
              <small class="text-muted">Nhập tên ngân hàng và số tài khoản của bạn</small>
            </div>

            <div class="mb-3 p-3 bg-light rounded">
              <p class="mb-0"><strong>Số dư hiện tại:</strong></p>
              <p class="h5 text-success mb-0">
                ₫<%= (user.wallet_balance || 0).toLocaleString('vi-VN') %>
              </p>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold py-3">
              <i class="bi bi-wallet2 me-2"></i>Nạp tiền ngay
            </button>
          </form>

          <button type="button" class="btn btn-outline-secondary w-100 mt-2" onclick="window.location.href='/'">
            <i class="bi bi-arrow-left me-2"></i>Quay lại
          </button>

          <div class="alert alert-info mt-4 mb-0">
            <small>
              <strong>💡 Lưu ý:</strong>
              <ul class="mb-0 mt-2">
                <li>Tiền nạp sẽ được lưu trong ví của bạn</li>
                <li>Dùng để thanh toán các đơn hàng trong ứng dụng</li>
                <li>Thanh toán an toàn và bảo mật</li>
              </ul>
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  // Hiển thị/ẩn trường tên và số tài khoản ngân hàng
  document.getElementById('paymentMethod').addEventListener('change', function() {
    const bankAccountSection = document.getElementById('bankAccountSection');
    const bankNameInput = document.getElementById('bankName');
    const bankAccountInput = document.getElementById('bankAccount');
    
    if (this.value === 'Tài khoản ngân hàng') {
      bankAccountSection.style.display = 'block';
      bankNameInput.required = true;
      bankAccountInput.required = true;
    } else {
      bankAccountSection.style.display = 'none';
      bankNameInput.required = false;
      bankAccountInput.required = false;
      bankNameInput.value = '';
      bankAccountInput.value = '';
    }
  });
</script>
